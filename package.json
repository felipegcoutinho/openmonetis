		"@types/node": "25.5.0",
		"@types/pg": "^8.20.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"dotenv": "^17.4.0",
		"drizzle-kit": "0.31.10",
		"knip": "^6.3.0",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2"
	}
}
